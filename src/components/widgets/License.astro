---
import { USER_NAME, t } from '@config'
import type { PostData } from '@interfaces/data'
import { Icon } from 'astro-icon/components'

const { title, url } = Astro.props as PostData
const encodedTitle = encodeURIComponent(title || '')
const encodedUrl = encodeURIComponent(url?.toString() || '')

const socialLinks = [
  { name: 'X (Twitter)', icon: 'ri:twitter-x-line', color: '#111111', url: `https://twitter.com/intent/tweet/?text=${encodedTitle}&url=${encodedUrl}` },
  { name: 'Telegram', icon: 'ri:telegram-line', color: '#26a5e4', url: `https://telegram.me/share/url?text=${encodedTitle}&url=${encodedUrl}` },
  { name: 'Reddit', icon: 'ri:reddit-line', color: '#ff4500', url: `https://reddit.com/submit/?url=${encodedUrl}&title=${encodedTitle}` },
  { name: 'Facebook', icon: 'ri:facebook-circle-line', color: '#0866ff', url: `https://facebook.com/sharer/sharer.php?u=${encodedUrl}` },
  { name: 'Email', icon: 'ri:mail-line', color: '#59616d', url: `mailto:?subject=${encodedTitle}&body=${encodedUrl}` },
]
---

<footer class="article-endcap not-prose" data-pagefind-ignore>
  <div class="endcap-mark" aria-hidden="true">
    <Icon name="lucide:check-check" class="h-5 w-5" />
  </div>

  <div class="endcap-copy">
    <strong>感谢阅读到这里</strong>
    <span>
      © {USER_NAME} ·
      <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed" target="_blank" rel="noopener noreferrer">
        CC BY-NC-SA 4.0
      </a>
    </span>
  </div>

  <button class="share-button" onclick="share_modal.showModal()">
    <Icon name="lucide:share-2" class="h-4 w-4" />
    {t('label.share')}
  </button>
</footer>

<dialog id="share_modal" class="modal modal-bottom sm:modal-middle">
  <div class="modal-box share-modal-box">
    <div class="share-modal-heading">
      <span><Icon name="lucide:send" class="h-5 w-5" /></span>
      <div>
        <h3>{t('label.shareCard')}</h3>
        <p>选择一个平台，或复制当前文章链接。</p>
      </div>
    </div>

    <div class="share-options">
      {socialLinks.map(({ name, icon, color, url: shareUrl }) => (
        <a
          href={shareUrl}
          class="share-option"
          style={`--share-color:${color};`}
          target="_blank"
          rel="noopener noreferrer"
          title={name}
        >
          <Icon name={icon} class="h-5 w-5" />
          <span>{name}</span>
        </a>
      ))}

      <button
        class="share-option copy-link-button"
        style="--share-color:oklch(var(--p));"
        onclick={`navigator.clipboard.writeText(window.location.href).then(() => {
          const label = this.querySelector('span');
          if (!label) return;
          label.textContent = '已复制';
          this.classList.add('is-copied');
          setTimeout(() => {
            label.textContent = '复制链接';
            this.classList.remove('is-copied');
          }, 1800);
        })`}
      >
        <Icon name="lucide:link" class="h-5 w-5" />
        <span>复制链接</span>
      </button>
    </div>

    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-ghost btn-sm rounded-xl">{t('label.close')}</button>
      </form>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>{t('label.close')}</button></form>
</dialog>

<style>
  .article-endcap {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.8rem;
    margin-top: 2.5rem;
    border-top: 1px solid oklch(var(--bc) / 0.09);
    padding-top: 1.1rem;
  }

  .endcap-mark {
    display: flex;
    width: 2.5rem;
    height: 2.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.8rem;
    background: oklch(var(--p) / 0.1);
    color: oklch(var(--p));
  }

  .endcap-copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
    line-height: 1.4;
  }

  .endcap-copy strong {
    font-size: 0.82rem;
  }

  .endcap-copy span {
    margin-top: 0.15rem;
    color: oklch(var(--bc) / 0.58);
    font-size: 0.65rem;
  }

  .endcap-copy a {
    color: oklch(var(--p));
    transition: opacity 180ms ease;
  }

  .endcap-copy a:hover {
    opacity: 0.72;
  }

  .share-button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid oklch(var(--p) / 0.24);
    border-radius: 999px;
    background: oklch(var(--p) / 0.07);
    padding: 0.55rem 0.8rem;
    color: oklch(var(--p));
    font-size: 0.72rem;
    font-weight: 800;
    transition: transform 180ms ease, background 180ms ease;
  }

  .share-button:hover {
    transform: translateY(-2px);
    background: oklch(var(--p) / 0.12);
  }

  .share-modal-box {
    width: min(92vw, 38rem);
    border: 1px solid oklch(var(--bc) / 0.1);
    border-radius: 1.4rem;
    background: oklch(var(--b1));
    padding: 1.25rem;
  }

  .share-modal-heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .share-modal-heading > span {
    display: flex;
    width: 2.8rem;
    height: 2.8rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.9rem;
    background: oklch(var(--p) / 0.1);
    color: oklch(var(--p));
  }

  .share-modal-heading h3 {
    font-size: 1rem;
    font-weight: 850;
  }

  .share-modal-heading p {
    margin-top: 0.12rem;
    color: oklch(var(--bc) / 0.58);
    font-size: 0.68rem;
  }

  .share-options {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.6rem;
    margin-top: 1rem;
  }

  .share-option {
    display: flex;
    min-height: 4.6rem;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.35rem;
    border: 1px solid color-mix(in oklab, var(--share-color), transparent 76%);
    border-radius: 0.9rem;
    background: color-mix(in oklab, var(--share-color), oklch(var(--b1)) 93%);
    color: var(--share-color);
    font-size: 0.66rem;
    font-weight: 750;
    transition: transform 180ms ease, background 180ms ease;
  }

  .share-option:hover,
  .share-option.is-copied {
    transform: translateY(-2px);
    background: color-mix(in oklab, var(--share-color), oklch(var(--b1)) 88%);
  }

  .modal-backdrop button {
    width: 100%;
    height: 100%;
    cursor: default;
    opacity: 0;
  }

  @media (max-width: 639px) {
    .article-endcap {
      grid-template-columns: auto minmax(0, 1fr);
    }

    .share-button {
      grid-column: 1 / -1;
      justify-content: center;
      border-radius: 0.8rem;
    }

    .share-modal-box {
      border-radius: 1.2rem 1.2rem 0 0;
    }

    .share-options {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
