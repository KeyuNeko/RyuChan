---
import { Icon } from "astro-icon/components";
import {
  SITE_ICP,
  SITE_ICP_ICON,
  SITE_ICP_LINK,
  SITE_POLICE,
  SITE_POLICE_ICON,
  SITE_POLICE_IMAGE,
  SITE_POLICE_LINK,
  SITE_FILING_DOMAINS,
} from "@config";

const filingDomains = SITE_FILING_DOMAINS
  .map((domain) => domain.trim().toLowerCase())
  .filter(Boolean);
const needsClientFilingCheck = filingDomains.length > 0;
---

<footer class="footer mt-auto flex w-full items-center justify-center border-t border-base-content/10 py-5 text-center text-xs text-base-content/65 md:text-sm">
  {(SITE_ICP || SITE_POLICE) && (
    <div
      class:list={["flex flex-wrap items-center justify-center gap-y-2", needsClientFilingCheck && "hidden"]}
      data-filing-records
      data-filing-domains={JSON.stringify(filingDomains)}
    >
      {SITE_POLICE && (
        <a
          href={SITE_POLICE_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 font-medium hover:text-primary"
        >
          {SITE_POLICE_IMAGE ? (
            <img src={SITE_POLICE_IMAGE} alt="" class="h-4 w-auto" aria-hidden="true" />
          ) : (
            <Icon name={SITE_POLICE_ICON} class="h-4 w-4" aria-hidden="true" />
          )}
          {SITE_POLICE}
        </a>
      )}
      {SITE_POLICE && SITE_ICP && <span class="mx-2 text-base-content/45" aria-hidden="true">|</span>}
      {SITE_ICP && (
        <a
          href={SITE_ICP_LINK}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 font-medium hover:text-primary"
        >
          <Icon name={SITE_ICP_ICON} class="h-4 w-4" aria-hidden="true" />
          {SITE_ICP}
        </a>
      )}
    </div>
  )}
</footer>

<script is:inline>
  (() => {
    const updateFilingVisibility = () => {
      const hostname = window.location.hostname.toLowerCase();

      document.querySelectorAll("[data-filing-records]").forEach((records) => {
        const domains = JSON.parse(records.dataset.filingDomains || "[]");
        const shouldShow = domains.length === 0 || domains.some((domain) =>
          hostname === domain || hostname.endsWith(`.${domain}`),
        );

        records.classList.toggle("hidden", !shouldShow);
      });
    };

    updateFilingVisibility();
    document.addEventListener("astro:page-load", updateFilingVisibility);
  })();
</script>
