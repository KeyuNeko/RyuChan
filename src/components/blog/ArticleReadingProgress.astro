---
import { Icon } from 'astro-icon/components'

interface Props {
  minutes?: number | string
}

const parsedMinutes = Math.max(1, Math.ceil(Number.parseFloat(String(Astro.props.minutes || 1)) || 1))
---

<div class="reading-progress-track" aria-hidden="true">
  <span id="reading-progress-bar"></span>
</div>

<div id="reading-progress-status" class="reading-progress-status" aria-live="polite">
  <span class="status-icon"><Icon name="lucide:book-open-check" class="h-4 w-4" /></span>
  <span>
    <strong id="reading-progress-percent">0%</strong>
    <small id="reading-progress-remaining">约需 {parsedMinutes} 分钟</small>
  </span>
</div>

<script define:vars={{ parsedMinutes }} is:inline>
  function initReadingProgress() {
    const article = document.getElementById('content');
    const bar = document.getElementById('reading-progress-bar');
    const status = document.getElementById('reading-progress-status');
    const percentLabel = document.getElementById('reading-progress-percent');
    const remainingLabel = document.getElementById('reading-progress-remaining');
    if (!article || !bar || !status || !percentLabel || !remainingLabel) return;

    let ticking = false;

    const update = () => {
      const rect = article.getBoundingClientRect();
      const start = window.scrollY + rect.top - 120;
      const end = start + article.offsetHeight - window.innerHeight * 0.45;
      const progress = Math.min(1, Math.max(0, (window.scrollY - start) / Math.max(1, end - start)));
      const percent = Math.round(progress * 100);
      const remaining = Math.max(0, Math.ceil(parsedMinutes * (1 - progress)));

      bar.style.transform = `scaleX(${progress})`;
      percentLabel.textContent = `${percent}%`;
      remainingLabel.textContent = remaining > 0 ? `还需约 ${remaining} 分钟` : '已读完';
      status.classList.toggle('is-visible', window.scrollY > start + 80 && progress < 1);
      ticking = false;
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    };

    window.addEventListener('scroll', requestUpdate, { passive: true });
    window.addEventListener('resize', requestUpdate, { passive: true });
    update();

    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', requestUpdate);
      window.removeEventListener('resize', requestUpdate);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initReadingProgress);
</script>

<style>
  .reading-progress-track {
    position: fixed;
    z-index: 100;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: oklch(var(--bc) / 0.08);
    pointer-events: none;
  }

  .reading-progress-track span {
    display: block;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, oklch(var(--p)), oklch(var(--s)), oklch(var(--a)));
    box-shadow: 0 0 12px oklch(var(--p) / 0.5);
    transform: scaleX(0);
    transform-origin: left;
  }

  .reading-progress-status {
    position: fixed;
    z-index: 45;
    bottom: 1.5rem;
    left: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    border: 1px solid oklch(var(--bc) / 0.1);
    border-radius: 999px;
    background: oklch(var(--b1) / 0.88);
    padding: 0.55rem 0.8rem 0.55rem 0.55rem;
    box-shadow: 0 16px 40px -24px oklch(var(--bc) / 0.7);
    opacity: 0;
    pointer-events: none;
    transform: translateY(12px);
    transition: opacity 220ms ease, transform 220ms ease;
    backdrop-filter: blur(14px);
  }

  .reading-progress-status.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .status-icon {
    display: flex;
    width: 2rem;
    height: 2rem;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: oklch(var(--p) / 0.12);
    color: oklch(var(--p));
  }

  .reading-progress-status > span:last-child {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .reading-progress-status strong {
    font-size: 0.75rem;
  }

  .reading-progress-status small {
    margin-top: 0.15rem;
    color: oklch(var(--bc) / 0.62);
    font-size: 0.62rem;
  }

  @media (max-width: 767px) {
    .reading-progress-status {
      display: none;
    }
  }
</style>
