---
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import dayjs from '@utils/dayjs'
import type { PostData } from '@interfaces/data'

interface Props extends PostData {
  index: number
}

const {
  title,
  description = '',
  image,
  pubDate,
  badge,
  categories = [],
  tags = [],
  word = '0',
  time = '0',
  url = '#',
  index,
} = Astro.props as Props

const palettes = [
  { accent: 'oklch(var(--p))', soft: 'oklch(var(--p) / 0.12)' },
  { accent: 'oklch(var(--s))', soft: 'oklch(var(--s) / 0.12)' },
  { accent: 'oklch(var(--a))', soft: 'oklch(var(--a) / 0.12)' },
  { accent: 'oklch(var(--in))', soft: 'oklch(var(--in) / 0.12)' },
]
const normalizedIndex = Number.isFinite(index) && index > 0 ? index : 1
const palette = palettes[(normalizedIndex - 1) % palettes.length]
const displayDate = pubDate ? dayjs(pubDate).format('YYYY年M月D日') : ''
const displayDescription = description.trim() || '点击进入文章，查看完整内容与这次记录背后的思考。'
---

<article
  class="timeline-post-card group"
  style={`--card-accent:${palette.accent};--card-soft:${palette.soft};`}
>
  <a href={url} class="cover-link" aria-label={`阅读《${title}》`}>
    {image ? (
      <Image
        src={image}
        alt={title}
        width={900}
        height={540}
        format="webp"
        loading="lazy"
        class="cover-image"
      />
    ) : (
      <div class="cover-placeholder">
        <Icon name="lucide:feather" class="h-12 w-12" />
      </div>
    )}
    <div class="cover-overlay"></div>
    <span class="sequence-number">NO. {String(normalizedIndex).padStart(2, '0')}</span>
    {badge && <span class="post-badge">{badge}</span>}
    <span class="cover-action">
      阅读文章
      <Icon name="lucide:arrow-up-right" class="h-4 w-4" />
    </span>
  </a>

  <div class="card-content">
    <div class="eyebrow-row">
      {categories.length > 0 ? (
        <a href={`/blog?category=${encodeURIComponent(categories[0])}#article-filter`} class="primary-category">
          <Icon name="lucide:folder" class="h-3.5 w-3.5" />
          {categories[0]}
        </a>
      ) : (
        <span class="primary-category">
          <Icon name="lucide:folder" class="h-3.5 w-3.5" />
          随笔
        </span>
      )}
      {displayDate && <time datetime={pubDate?.toISOString()}>{displayDate}</time>}
    </div>

    <h2 class="card-title">
      <a href={url}>{title}</a>
    </h2>
    <p class="card-description">{displayDescription}</p>

    <div class="card-footer">
      <div class="tag-list">
        {tags.slice(0, 3).map((tag) => (
          <a href={`/blog?tag=${encodeURIComponent(tag)}#article-filter`} class="tag-chip">#{tag}</a>
        ))}
      </div>
      <div class="reading-meta">
        <span><Icon name="lucide:text" class="h-3.5 w-3.5" />{word} 字</span>
        <span><Icon name="lucide:clock-3" class="h-3.5 w-3.5" />{time} 分钟</span>
      </div>
    </div>
  </div>
</article>

<style>
  .timeline-post-card {
    position: relative;
    overflow: hidden;
    border: 1px solid oklch(var(--bc) / 0.1);
    border-radius: 1.5rem;
    background: oklch(var(--b1) / 0.96);
    box-shadow: 0 18px 50px -34px oklch(var(--bc) / 0.55);
    transition: transform 300ms ease, box-shadow 300ms ease, border-color 300ms ease;
  }

  .timeline-post-card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    z-index: 10;
    background: linear-gradient(180deg, var(--card-accent), transparent 78%);
  }

  .timeline-post-card:hover {
    transform: translateY(-6px);
    border-color: color-mix(in oklab, var(--card-accent), transparent 65%);
    box-shadow: 0 28px 70px -38px color-mix(in oklab, var(--card-accent), black 35%);
  }

  .cover-link {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--card-soft);
  }

  .cover-image,
  .cover-placeholder {
    width: 100%;
    height: 100%;
  }

  .cover-image {
    object-fit: cover;
    transition: transform 700ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .group:hover .cover-image {
    transform: scale(1.06);
  }

  .cover-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--card-accent);
    background:
      radial-gradient(circle at 22% 24%, var(--card-soft), transparent 32%),
      linear-gradient(135deg, oklch(var(--b2)), oklch(var(--b1)));
  }

  .cover-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 45%, rgb(0 0 0 / 0.58));
  }

  .sequence-number,
  .post-badge,
  .cover-action {
    position: absolute;
    z-index: 2;
  }

  .sequence-number {
    top: 1rem;
    left: 1rem;
    border: 1px solid rgb(255 255 255 / 0.24);
    border-radius: 999px;
    background: rgb(0 0 0 / 0.28);
    padding: 0.35rem 0.65rem;
    color: white;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    backdrop-filter: blur(12px);
  }

  .post-badge {
    top: 1rem;
    right: 1rem;
    border-radius: 999px;
    background: var(--card-accent);
    padding: 0.35rem 0.7rem;
    color: oklch(var(--pc));
    font-size: 0.7rem;
    font-weight: 800;
  }

  .cover-action {
    right: 1rem;
    bottom: 0.9rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: white;
    font-size: 0.8rem;
    font-weight: 700;
    opacity: 0.82;
    transition: opacity 200ms ease, transform 200ms ease;
  }

  .group:hover .cover-action {
    opacity: 1;
    transform: translateX(2px);
  }

  .card-content {
    position: relative;
    padding: 1.35rem 1.4rem 1.3rem;
    background: radial-gradient(circle at 100% 0%, var(--card-soft), transparent 34%);
  }

  .eyebrow-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    color: oklch(var(--bc) / 0.65);
    font-size: 0.72rem;
  }

  .primary-category {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 999px;
    background: var(--card-soft);
    padding: 0.35rem 0.65rem;
    color: var(--card-accent);
    font-weight: 800;
  }

  .card-title {
    margin-top: 0.9rem;
    color: oklch(var(--bc));
    font-size: clamp(1.25rem, 2.2vw, 1.65rem);
    font-weight: 800;
    line-height: 1.35;
    letter-spacing: -0.015em;
    text-wrap: balance;
  }

  .card-title a {
    transition: color 200ms ease;
  }

  .card-title a:hover {
    color: var(--card-accent);
  }

  .card-description {
    display: -webkit-box;
    margin-top: 0.7rem;
    overflow: hidden;
    color: oklch(var(--bc) / 0.74);
    font-size: 0.9rem;
    line-height: 1.75;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: 1.15rem;
    padding-top: 1rem;
    border-top: 1px solid oklch(var(--bc) / 0.08);
  }

  .tag-list {
    display: flex;
    min-width: 0;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag-chip {
    border-radius: 0.45rem;
    background: oklch(var(--b2) / 0.75);
    padding: 0.25rem 0.45rem;
    color: oklch(var(--bc) / 0.7);
    font-size: 0.68rem;
    font-weight: 650;
    transition: background 200ms ease, color 200ms ease;
  }

  .tag-chip:hover {
    background: var(--card-soft);
    color: var(--card-accent);
  }

  .reading-meta {
    display: flex;
    flex-shrink: 0;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
    color: oklch(var(--bc) / 0.62);
    font-size: 0.68rem;
  }

  .reading-meta span {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  @media (max-width: 639px) {
    .timeline-post-card {
      border-radius: 1.2rem;
    }

    .card-content {
      padding: 1rem 1rem 1.05rem;
    }

    .card-title {
      font-size: 1.2rem;
    }

    .card-footer {
      align-items: flex-start;
      flex-direction: column;
    }

    .reading-meta {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
