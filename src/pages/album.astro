---
import BaseLayout from '@layouts/BaseLayout.astro'
import { albums, formattedDate } from '@/data/albums'
import { Icon } from 'astro-icon/components'
---

<BaseLayout
  title="相册"
  bannerTitle="相册"
  bannerSubtitle="在光影里保存生活，也保存当时的心情"
  isIndexed={false}
>
  <section aria-labelledby="albums-title">
    <header class="mb-8">
      <p class="mb-2 text-sm font-semibold text-primary">MOMENTS</p>
      <h1 id="albums-title" class="text-3xl font-bold">相册</h1>
      <p class="mt-3 max-w-2xl text-base-content/75">一些值得被记住的日常、旅途和片刻。</p>
    </header>

    {albums.length > 0 ? (
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {albums.map((album) => (
          <article class="overflow-hidden rounded-2xl border border-base-content/10 bg-base-100 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
            <a href={`/photo-wall?id=${album.id}`} class="group block">
              <div class="grid h-56 grid-cols-3 gap-1 overflow-hidden bg-base-200">
                {(album.photos || []).slice(0, 3).map((photo, index) => (
                  <img
                    src={photo.src}
                    alt={photo.title || album.event}
                    loading="lazy"
                    class:list={["h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]", index === 0 && "col-span-2"]}
                  />
                ))}
                {(!album.photos || album.photos.length === 0) && (
                  <div class="col-span-3 flex h-full items-center justify-center text-base-content/35">
                    <Icon name="lucide:image" class="h-12 w-12" />
                  </div>
                )}
              </div>
              <div class="p-5">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h2 class="text-xl font-bold transition-colors group-hover:text-primary">{album.icon} {album.event}</h2>
                    {album.title && <p class="mt-1 text-sm text-base-content/75">{album.title}</p>}
                  </div>
                  <time class="shrink-0 text-xs text-base-content/65">{formattedDate(album.date)}</time>
                </div>
                {album.description && <p class="mt-3 line-clamp-2 text-sm leading-6 text-base-content/75">{album.description}</p>}
                <p class="mt-4 inline-flex items-center gap-1.5 text-xs font-semibold text-primary">
                  <Icon name="lucide:images" class="h-3.5 w-3.5" />
                  {(album.photos || []).length} 张照片
                </p>
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <Icon name="lucide:camera" class="empty-icon" />
        <p class="empty-text font-semibold">照片还在路上</p>
        <p class="mt-2 text-sm text-base-content/70">下一段值得记录的时光，会出现在这里。</p>
      </div>
    )}
  </section>
</BaseLayout>
