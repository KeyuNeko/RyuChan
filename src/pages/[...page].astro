---
import type { Post, Page } from '@interfaces/data'
import PostCard from '@components/PostCard.astro'
import BaseLayout from '@layouts/BaseLayout.astro'
import Pagination from '@components/widgets/Pagination.astro'
import CardGroup from '@components/temple/CardGroup.astro'
import { Icon } from 'astro-icon/components'
import {
  t,
  USER_AVATAR,
  USER_NAME,
  USER_DESCRIPTION,
  USER_SIDEBAR_SOCIAL_ICONS,
} from '@config'
import { generatePageLinks } from '@utils/blogUtils'
import { getMainBlogPaginationPaths } from '@utils/paginationUtils'

export async function getStaticPaths({ paginate }: { paginate: any }) {
  return getMainBlogPaginationPaths({ paginate })
}

const { page }: { page: Page } = Astro.props
const totalPages = Math.ceil(page.total / page.size)
const pageLinks = generatePageLinks(totalPages)

const discoveryLinks = [
  { href: '/blog/archives', icon: 'lucide:archive', title: t('label.archivePage'), description: t('label.archivesPageDescription'), color: 'text-accent bg-accent/10' },
  { href: '/blog/categories', icon: 'lucide:folder', title: t('label.categoryPage'), description: t('label.categoriesPageDescription'), color: 'text-primary bg-primary/10' },
  { href: '/blog/tags', icon: 'lucide:tag', title: t('label.tagPage'), description: t('label.tagsPageDescription'), color: 'text-secondary bg-secondary/10' },
  { href: '/blog/search', icon: 'lucide:search', title: t('label.searchPage'), description: t('label.searchPageDescription'), color: 'text-info bg-info/10' },
]
---

<BaseLayout title="Blog" isIndexed={false} bannerVariant="home">
  <section class="overflow-hidden rounded-2xl border border-base-content/10 bg-base-100 shadow-sm lg:hidden">
    <div class="flex min-h-36">
      <a href="/about" class="relative w-32 shrink-0 overflow-hidden sm:w-40">
        <img class="h-full w-full object-cover" src={USER_AVATAR} alt={USER_NAME} loading="eager" />
        <div class="absolute inset-y-0 right-0 w-12 bg-gradient-to-l from-base-100"></div>
      </a>
      <div class="flex min-w-0 flex-1 flex-col justify-center p-4 sm:p-5">
        <a href="/about" class="truncate text-xl font-bold hover:text-primary">{USER_NAME}</a>
        <p class="mt-2 line-clamp-2 text-sm leading-6 text-base-content/75">{USER_DESCRIPTION}</p>
        <ul class="mt-3 flex flex-wrap gap-3">
          {USER_SIDEBAR_SOCIAL_ICONS.map((icon) => (
            <li>
              <a href={icon.href} target="_blank" rel="noopener noreferrer" aria-label={icon.ariaLabel} class="text-base-content/70 transition-colors hover:text-primary">
                <Icon name={icon.svg} class="h-5 w-5" />
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section aria-labelledby="latest-posts-title">
    <header class="mb-4 flex items-end justify-between gap-4">
      <div>
        <p class="mb-1 text-sm font-semibold text-primary">LATEST</p>
        <h1 id="latest-posts-title" class="text-2xl font-bold md:text-3xl">最新文章</h1>
      </div>
      <a href="/blog" class="hidden items-center gap-1 text-sm font-semibold text-base-content/70 hover:text-primary sm:inline-flex">
        进入文章区 <Icon name="lucide:arrow-right" class="h-4 w-4" />
      </a>
    </header>

    <CardGroup cols="1">
      {page.data.map((blog: Post) => (
        <PostCard
          title={blog.data.title}
          image={blog.data.image}
          description={blog.data.description}
          url={'/blog/' + blog.slug}
          pubDate={blog.data.pubDate}
          badge={blog.data.badge}
          categories={blog.data.categories}
          tags={blog.data.tags}
          word={blog.remarkPluginFrontmatter.totalCharCount}
          time={blog.remarkPluginFrontmatter.readingTime}
        />
      ))}
    </CardGroup>
    <Pagination page={page} totalPages={totalPages} pageLinks={pageLinks} baseUrl={``} />
  </section>

  <section aria-labelledby="discover-title" class="mt-2">
    <header class="mb-4">
      <p class="mb-1 text-sm font-semibold text-primary">DISCOVER</p>
      <h2 id="discover-title" class="text-xl font-bold md:text-2xl">继续探索</h2>
    </header>
    <div class="grid grid-cols-2 gap-3">
      {discoveryLinks.map((item) => (
        <a href={item.href} class="group rounded-2xl border border-base-content/10 bg-base-100 p-3 shadow-sm transition hover:-translate-y-0.5 hover:border-primary/25 hover:shadow-md sm:p-4">
          <div class="flex items-center gap-3">
            <span class:list={["flex h-9 w-9 shrink-0 items-center justify-center rounded-xl", item.color]}>
              <Icon name={item.icon} class="h-5 w-5" />
            </span>
            <div class="min-w-0">
              <h3 class="truncate text-sm font-bold transition-colors group-hover:text-primary sm:text-base">{item.title}</h3>
              <p class="mt-0.5 truncate text-xs text-base-content/70">{item.description}</p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
