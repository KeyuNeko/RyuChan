---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { Icon } from 'astro-icon/components'
import { albums } from '@/data/albums'
import '@fancyapps/ui/dist/fancybox/fancybox.css'

const id = Astro.url.searchParams.get('id') || ''
const album = id ? albums.find((item) => item.id === id) : null
---

<BaseLayout
  title={album?.event || '照片集'}
  bannerTitle={album?.event || '照片集'}
  bannerSubtitle={album?.title || '从相册中选择一段时光'}
  isIndexed={false}
>
  <section aria-labelledby="photo-wall-title">
    <header class="mb-8">
      <a href="/album" class="mb-4 inline-flex items-center gap-2 text-sm font-semibold text-base-content/70 transition-colors hover:text-primary">
        <Icon name="lucide:arrow-left" class="h-4 w-4" />
        返回相册
      </a>
      <h1 id="photo-wall-title" class="flex items-center gap-3 text-3xl font-bold">
        <Icon name="lucide:camera" class="text-primary" />
        <span>{album ? `${album.icon || ''} ${album.event}` : '照片集'}</span>
      </h1>
      <p class="mt-3 text-base-content/75">{album?.description || album?.title || '暂时没有可展示的照片。'}</p>
    </header>

    {album?.photos?.length ? (
      <div id="photo-wall-grid" class="columns-1 gap-4 sm:columns-2 lg:columns-3">
        {album.photos.map((photo) => (
          <figure class="group mb-4 break-inside-avoid overflow-hidden rounded-2xl border border-base-content/10 bg-base-100 shadow-sm">
            <a href={photo.src} data-fancybox="gallery" data-caption={photo.description || photo.title || ''}>
              <img src={photo.src} alt={photo.title || album.event} loading="lazy" class="w-full object-cover transition duration-500 group-hover:scale-[1.02]" />
            </a>
            {(photo.title || photo.description) && (
              <figcaption class="p-4">
                {photo.title && <h2 class="font-semibold">{photo.title}</h2>}
                {photo.description && <p class="mt-1 text-sm leading-6 text-base-content/75">{photo.description}</p>}
              </figcaption>
            )}
          </figure>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <Icon name="lucide:image-off" class="empty-icon" />
        <p class="empty-text font-semibold">这个相册暂时没有照片</p>
        <a href="/album" class="btn btn-sm btn-primary mt-4 rounded-xl">查看其他相册</a>
      </div>
    )}
  </section>
</BaseLayout>

<script>
  import { Fancybox } from '@fancyapps/ui'

  document.addEventListener('astro:page-load', () => {
    Fancybox.bind('[data-fancybox="gallery"]', { Hash: false })
  })
</script>
