---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Card from "@/components/temple/Card.astro";
---

<BaseLayout title="关于" isIndexed={false}>
  <Card class="p-6 md:p-8">
    <div class="space-y-4">
      <h1 class="text-3xl font-bold">关于我</h1>
      <p class="text-base-content/70">此页面尚未填写个人介绍。</p>
      <div class="rounded-xl bg-base-200 p-4 text-sm leading-7 text-base-content/80">
        请通过右上角的“编辑”按钮，填写你的头像、姓名、职业/简介、社交链接、个人经历和技术栈。
      </div>
      <a href="/about-edit" class="btn btn-primary">编辑关于页</a>
    </div>
  </Card>
</BaseLayout>
