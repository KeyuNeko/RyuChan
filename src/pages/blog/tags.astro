---
import BaseLayout from '@layouts/BaseLayout.astro'
import BlogSectionHero from '@components/blog/BlogSectionHero.astro'
import { Icon } from 'astro-icon/components'
import { getAllPosts, getTagsWithCount } from '@utils/blogUtils'

const allPosts = await getAllPosts()
const tagEntries = Array.from(getTagsWithCount(allPosts).entries()).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
const maxCount = Math.max(1, ...tagEntries.map(([, count]) => count))
const palette = ['oklch(var(--p))', 'oklch(var(--s))', 'oklch(var(--a))', 'oklch(var(--in))']
---

<BaseLayout
  title="文章标签"
  bannerTitle="文章标签"
  bannerSubtitle="用关键词连接散落在不同文章里的灵感"
  showSidebar={false}
  isIndexed={false}
>
  <BlogSectionHero
    eyebrow="DISCOVER BY KEYWORD"
    title="循着关键词发现内容"
    description="标签跨越分类，把相似的技术、想法与兴趣连接起来。出现得越多，视觉权重也越高。"
    icon="lucide:tags"
    count={tagEntries.length}
    countLabel="个标签"
    accent="secondary"
  />

  <section class="tag-panel" aria-label="文章标签云">
    {tagEntries.length > 0 ? (
      <div class="tag-cloud">
        {tagEntries.map(([tag, count], index) => {
          const weight = 0.92 + (count / maxCount) * 0.42
          return (
            <a
              href={`/blog/tag/${encodeURIComponent(tag)}`}
              class="tag-item"
              style={`--tag-accent:${palette[index % palette.length]};--tag-scale:${weight};--tag-delay:${Math.min(index * 35, 350)}ms;`}
            >
              <Icon name="lucide:hash" class="h-4 w-4" />
              <span>{tag}</span>
              <strong>{count}</strong>
            </a>
          )
        })}
      </div>
    ) : (
      <div class="empty-state"><Icon name="lucide:tags" class="empty-icon" /><p class="empty-text">还没有文章标签</p></div>
    )}

    <footer class="tag-legend">
      <span><i class="legend-dot"></i> 数字表示相关文章数量</span>
      <a href="/blog/search">找不到想要的？试试全文搜索 <Icon name="lucide:arrow-up-right" class="h-3.5 w-3.5" /></a>
    </footer>
  </section>
</BaseLayout>

<style>
  .tag-panel {
    overflow: hidden;
    border: 1px solid oklch(var(--bc) / 0.09);
    border-radius: 1.65rem;
    background:
      radial-gradient(circle at 50% 0%, oklch(var(--s) / 0.09), transparent 34%),
      oklch(var(--b1) / 0.92);
    padding: clamp(1.25rem, 4vw, 2.5rem);
    box-shadow: 0 20px 60px -48px oklch(var(--bc) / 0.65);
  }

  .tag-cloud {
    display: flex;
    min-height: 14rem;
    align-content: center;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .tag-item {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    border: 1px solid color-mix(in oklab, var(--tag-accent), transparent 76%);
    border-radius: 999px;
    background: color-mix(in oklab, var(--tag-accent), oklch(var(--b1)) 91%);
    padding: 0.55rem 0.7rem 0.55rem 0.65rem;
    color: var(--tag-accent);
    font-size: calc(0.78rem * var(--tag-scale));
    font-weight: 760;
    opacity: 0;
    transform: translateY(10px);
    animation: tag-in 450ms ease forwards;
    animation-delay: var(--tag-delay);
    transition: transform 200ms ease, box-shadow 200ms ease, background 200ms ease;
  }

  .tag-item:hover {
    transform: translateY(-3px) scale(1.03);
    background: color-mix(in oklab, var(--tag-accent), oklch(var(--b1)) 86%);
    box-shadow: 0 14px 30px -20px var(--tag-accent);
  }

  .tag-item strong {
    display: inline-flex;
    min-width: 1.5rem;
    height: 1.5rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: color-mix(in oklab, var(--tag-accent), transparent 84%);
    font-size: 0.65rem;
  }

  .tag-legend {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.5rem;
    border-top: 1px solid oklch(var(--bc) / 0.08);
    padding-top: 1rem;
    color: oklch(var(--bc) / 0.58);
    font-size: 0.68rem;
  }

  .tag-legend span,
  .tag-legend a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .tag-legend a {
    color: oklch(var(--s));
    font-weight: 750;
  }

  .legend-dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: oklch(var(--s));
    box-shadow: 0 0 0 4px oklch(var(--s) / 0.1);
  }

  @keyframes tag-in {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 639px) {
    .tag-panel {
      border-radius: 1.3rem;
      padding: 1.15rem;
    }

    .tag-cloud {
      min-height: 10rem;
      justify-content: flex-start;
      gap: 0.5rem;
    }

    .tag-item {
      font-size: 0.78rem;
    }

    .tag-legend {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
