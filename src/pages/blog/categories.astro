---
import BaseLayout from '@layouts/BaseLayout.astro'
import BlogSectionHero from '@components/blog/BlogSectionHero.astro'
import { Icon } from 'astro-icon/components'
import dayjs from '@utils/dayjs'
import { DATE_FORMAT } from '@config'
import { getAllPosts, getCategoriesWithPosts } from '@utils/blogUtils'

const allPosts = await getAllPosts()
const categoryEntries = Array.from(getCategoriesWithPosts(allPosts).entries())
  .map(([category, posts]) => [category, posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())] as const)
  .sort((a, b) => b[1].length - a[1].length || a[0].localeCompare(b[0]))

const palette = ['oklch(var(--p))', 'oklch(var(--s))', 'oklch(var(--a))', 'oklch(var(--in))']
---

<BaseLayout
  title="文章分类"
  bannerTitle="文章分类"
  bannerSubtitle="从主题出发，找到你真正想读的内容"
  showSidebar={false}
  isIndexed={false}
>
  <BlogSectionHero
    eyebrow="EXPLORE BY TOPIC"
    title="按主题探索文章"
    description="每个分类都是一条清晰的阅读路径，从技术实践到生活随笔，快速进入感兴趣的主题。"
    icon="lucide:folders"
    count={categoryEntries.length}
    countLabel="个分类"
    accent="primary"
  />

  {categoryEntries.length > 0 ? (
    <section class="category-grid" aria-label="文章分类列表">
      {categoryEntries.map(([category, posts], index) => (
        <article class="category-card" style={`--category-accent:${palette[index % palette.length]};`}>
          <header>
            <span class="category-icon"><Icon name="lucide:folder-open" class="h-5 w-5" /></span>
            <span class="category-copy">
              <span class="category-kicker">TOPIC {String(index + 1).padStart(2, '0')}</span>
              <h2>{category}</h2>
            </span>
            <strong>{posts.length}</strong>
          </header>

          <ul>
            {posts.slice(0, 3).map((post) => (
              <li>
                <a href={`/blog/${post.slug}`}>
                  <span>{post.data.title}</span>
                  <time datetime={post.data.pubDate.toISOString()}>{dayjs(post.data.pubDate).format(DATE_FORMAT)}</time>
                </a>
              </li>
            ))}
          </ul>

          <a href={`/blog/category/${encodeURIComponent(category)}`} class="category-action">
            浏览该分类的全部文章
            <Icon name="lucide:arrow-right" class="h-4 w-4" />
          </a>
        </article>
      ))}
    </section>
  ) : (
    <div class="empty-state"><Icon name="lucide:folder-x" class="empty-icon" /><p class="empty-text">还没有文章分类</p></div>
  )}
</BaseLayout>

<style>
  .category-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .category-card {
    position: relative;
    overflow: hidden;
    border: 1px solid oklch(var(--bc) / 0.09);
    border-radius: 1.4rem;
    background:
      radial-gradient(circle at 100% 0%, color-mix(in oklab, var(--category-accent), transparent 87%), transparent 34%),
      oklch(var(--b1) / 0.94);
    padding: 1.25rem;
    box-shadow: 0 18px 50px -42px oklch(var(--bc) / 0.65);
    transition: transform 250ms ease, border-color 250ms ease, box-shadow 250ms ease;
  }

  .category-card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: linear-gradient(var(--category-accent), transparent 76%);
  }

  .category-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in oklab, var(--category-accent), transparent 66%);
    box-shadow: 0 26px 60px -40px color-mix(in oklab, var(--category-accent), black 38%);
  }

  .category-card header {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.8rem;
  }

  .category-icon {
    display: flex;
    width: 2.8rem;
    height: 2.8rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.9rem;
    background: color-mix(in oklab, var(--category-accent), transparent 87%);
    color: var(--category-accent);
  }

  .category-copy {
    display: flex;
    min-width: 0;
    flex-direction: column;
  }

  .category-kicker {
    color: var(--category-accent);
    font-size: 0.6rem;
    font-weight: 850;
    letter-spacing: 0.12em;
  }

  .category-card h2 {
    margin-top: 0.1rem;
    overflow: hidden;
    font-size: 1.15rem;
    font-weight: 850;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .category-card header > strong {
    color: var(--category-accent);
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
  }

  .category-card ul {
    display: grid;
    gap: 0.35rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .category-card li a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    border-radius: 0.75rem;
    padding: 0.55rem 0.65rem;
    color: oklch(var(--bc) / 0.76);
    font-size: 0.78rem;
    transition: background 180ms ease, color 180ms ease;
  }

  .category-card li a:hover {
    background: color-mix(in oklab, var(--category-accent), transparent 92%);
    color: var(--category-accent);
  }

  .category-card li span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .category-card time {
    flex-shrink: 0;
    color: oklch(var(--bc) / 0.5);
    font-size: 0.65rem;
  }

  .category-action {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1rem;
    border-top: 1px solid oklch(var(--bc) / 0.08);
    padding-top: 0.85rem;
    color: var(--category-accent);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .category-action :global(svg) {
    transition: transform 180ms ease;
  }

  .category-action:hover :global(svg) {
    transform: translateX(3px);
  }

  @media (max-width: 767px) {
    .category-grid {
      grid-template-columns: 1fr;
    }

    .category-card {
      border-radius: 1.2rem;
      padding: 1rem;
    }
  }
</style>
