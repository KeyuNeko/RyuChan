---
import { getCategoryPaginationPaths } from '@utils/paginationUtils'

export async function getStaticPaths({ paginate }: { paginate: any }) {
  return getCategoryPaginationPaths({ paginate })
}

const { category } = Astro.params as { category: string }
return Astro.redirect(`/blog?category=${encodeURIComponent(category)}#article-filter`)
---
