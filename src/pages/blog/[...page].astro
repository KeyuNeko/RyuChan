---
import type { Page } from '@interfaces/data'
import BaseLayout from '@layouts/BaseLayout.astro'
import PostCard from '@components/PostCard.astro'
import PostGridCard from '@components/PostGridCard.astro'
import ArticleFilterBar from '@components/blog/ArticleFilterBar.astro'
import Pagination from '@components/widgets/Pagination.astro'
import { Icon } from 'astro-icon/components'
import { generatePageLinks, getAllPosts } from '@utils/blogUtils'
import { getMainBlogPaginationPaths } from '@utils/paginationUtils'

export async function getStaticPaths({ paginate }: { paginate: any }) {
  return getMainBlogPaginationPaths({ paginate })
}

const { page }: { page: Page } = Astro.props
const totalPages = Math.ceil(page.total / page.size)
const pageLinks = generatePageLinks(totalPages)
const currentPage = (page as Page & { currentPage?: number }).currentPage ?? page.current ?? 1
const paginationPage: Page = { ...page, current: currentPage }

const allPosts = await getAllPosts()
const countTaxonomy = (key: 'categories' | 'tags') => [...allPosts
  .flatMap((post) => post.data[key] || [])
  .reduce((counts, item) => counts.set(item, (counts.get(item) || 0) + 1), new Map<string, number>())
  .entries()]
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name))
const categories = countTaxonomy('categories')
const tags = countTaxonomy('tags')

const quickLinks = [
  { href: '/blog/archives', label: '文章归档', icon: 'lucide:archive' },
  { href: '#article-filter', label: '内容筛选', icon: 'lucide:sliders-horizontal' },
]
---

<BaseLayout
  title="文章"
  bannerTitle="文章"
  bannerSubtitle="按时间记录，也按兴趣发现"
  showSidebar={false}
  isIndexed={false}
>
  <section class="article-toolbar" aria-labelledby="article-list-title">
    <div>
      <p class="toolbar-kicker"><Icon name="lucide:notebook-pen" class="h-4 w-4" /> WRITING</p>
      <h1 id="article-list-title">全部文章</h1>
      <p class="toolbar-meta">共 {page.total} 篇 · 第 {currentPage} / {Math.max(totalPages, 1)} 页</p>
    </div>
    <div class="article-actions">
      <nav class="article-tools" aria-label="文章工具">
        {quickLinks.map((item) => (
          <a href={item.href} title={item.label}>
            <Icon name={item.icon} class="h-4 w-4" />
            <span>{item.label}</span>
          </a>
        ))}
      </nav>
      <div class="article-view-toggle" data-article-view-toggle aria-label="文章视图">
        <button type="button" data-article-view="list" aria-label="列表视图" title="列表视图"><Icon name="lucide:list" class="h-4 w-4" /></button>
        <button type="button" data-article-view="grid" aria-label="网格视图" title="网格视图"><Icon name="lucide:layout-grid" class="h-4 w-4" /></button>
      </div>
    </div>
  </section>

  <ArticleFilterBar categories={categories} tags={tags} />

  {page.data.length > 0 ? (
    <div class="article-collection" data-article-collection data-view="list">
      {page.data.map((blog) => (
        <article
          data-article-item
          data-slug={blog.slug}
          data-categories={JSON.stringify(blog.data.categories || [])}
          data-tags={JSON.stringify(blog.data.tags || [])}
          data-search={[blog.data.title, blog.data.description, ...(blog.data.categories || []), ...(blog.data.tags || [])].join(' ').toLocaleLowerCase()}
        >
          <div class="article-card-list">
            <PostCard
              title={blog.data.title}
              image={blog.data.image}
              description={blog.data.description}
              url={`/blog/${blog.slug}`}
              pubDate={blog.data.pubDate}
              badge={blog.data.badge}
              categories={blog.data.categories}
              tags={blog.data.tags}
              word={blog.remarkPluginFrontmatter.totalCharCount}
              time={blog.remarkPluginFrontmatter.readingTime}
            />
          </div>
          <div class="article-card-grid">
            <PostGridCard
              title={blog.data.title}
              image={blog.data.image}
              description={blog.data.description}
              url={`/blog/${blog.slug}`}
              pubDate={blog.data.pubDate}
              categories={blog.data.categories}
              tags={blog.data.tags}
              word={blog.remarkPluginFrontmatter.totalCharCount}
              time={blog.remarkPluginFrontmatter.readingTime}
            />
          </div>
        </article>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <Icon name="lucide:notebook-pen" class="empty-icon" />
      <p class="empty-text">文章正在酝酿中</p>
    </div>
  )}

  <div class="article-pagination">
    <Pagination page={paginationPage} totalPages={totalPages} pageLinks={pageLinks} baseUrl="/blog" />
  </div>
</BaseLayout>

<style>
  .article-toolbar {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid oklch(var(--bc) / 0.12);
    padding: 0.35rem 0 1rem;
  }

  .toolbar-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: oklch(var(--p));
    font-size: 0.72rem;
    font-weight: 800;
  }

  .article-toolbar h1 {
    margin-top: 0.25rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 850;
  }

  .toolbar-meta {
    margin-top: 0.2rem;
    color: oklch(var(--bc) / 0.58);
    font-size: 0.78rem;
  }

  .article-actions,
  .article-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .article-actions { align-items: center; justify-content: flex-end; }

  .article-tools a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid oklch(var(--bc) / 0.12);
    border-radius: 0.55rem;
    padding: 0.48rem 0.65rem;
    color: oklch(var(--bc) / 0.7);
    font-size: 0.75rem;
    font-weight: 700;
    transition: border-color 160ms ease, color 160ms ease, background 160ms ease;
  }

  .article-tools a:hover {
    border-color: oklch(var(--p) / 0.45);
    background: oklch(var(--p) / 0.08);
    color: oklch(var(--p));
  }

  .article-view-toggle {
    display: inline-flex;
    overflow: hidden;
    border: 1px solid oklch(var(--bc) / 0.12);
    border-radius: 0.55rem;
  }

  .article-view-toggle button {
    display: grid;
    width: 2rem;
    height: 2rem;
    place-items: center;
    color: oklch(var(--bc) / 0.6);
    transition: background 160ms ease, color 160ms ease;
  }

  .article-view-toggle button + button { border-left: 1px solid oklch(var(--bc) / 0.12); }
  .article-view-toggle button:hover,
  .article-view-toggle button.is-active { background: oklch(var(--p) / 0.1); color: oklch(var(--p)); }

  .article-pagination {
    margin-top: 1.25rem;
    border-top: 1px solid oklch(var(--bc) / 0.1);
    padding-top: 1rem;
  }

  .article-collection[data-view='list'] {
    display: grid;
    gap: 1rem;
  }

  .article-card-grid { display: none; }
  .article-collection[data-view='grid'] { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
  .article-collection[data-view='grid'] > article { min-width: 0; }
  .article-collection[data-view='grid'] .article-card-list { display: none; }
  .article-collection[data-view='grid'] .article-card-grid { display: block; height: 100%; }
  .article-collection > article.hidden { display: none !important; }

  @media (max-width: 640px) {
    .article-toolbar {
      align-items: start;
      flex-direction: column;
    }

    .article-actions,
    .article-tools {
      justify-content: flex-start;
    }

    .article-collection[data-view='grid'] { grid-template-columns: 1fr; }
  }
</style>

<script>
  function initArticleViewToggle() {
    document.querySelectorAll<HTMLElement>('[data-article-collection]').forEach((collection) => {
      if (collection.dataset.viewInitialized) return
      collection.dataset.viewInitialized = 'true'

      const toggle = document.querySelector<HTMLElement>('[data-article-view-toggle]')
      const buttons = toggle ? [...toggle.querySelectorAll<HTMLButtonElement>('[data-article-view]')] : []
      const storedView = localStorage.getItem('blog-article-view')
      const setView = (view: 'list' | 'grid') => {
        collection.dataset.view = view
        buttons.forEach((button) => {
          const active = button.dataset.articleView === view
          button.classList.toggle('is-active', active)
          button.setAttribute('aria-pressed', String(active))
        })
        localStorage.setItem('blog-article-view', view)
      }

      setView(storedView === 'grid' ? 'grid' : 'list')
      buttons.forEach((button) => button.addEventListener('click', () => setView(button.dataset.articleView === 'grid' ? 'grid' : 'list')))
    })
  }

  initArticleViewToggle()
  document.addEventListener('astro:page-load', initArticleViewToggle)
</script>
