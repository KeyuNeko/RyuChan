---
import BaseLayout from '@layouts/BaseLayout.astro'
import BlogSectionHero from '@components/blog/BlogSectionHero.astro'
import { Icon } from 'astro-icon/components'
---

<BaseLayout
  title="搜索文章"
  bannerTitle="搜索文章"
  bannerSubtitle="输入一个词，定位散落在全文里的答案"
  showSidebar={false}
  isIndexed={false}
>
  <BlogSectionHero
    eyebrow="SEARCH THE LIBRARY"
    title="从全部文字中寻找答案"
    description="支持标题与正文全文检索。输入技术名词、片段或灵感关键词，即可快速定位相关内容。"
    icon="lucide:search"
    accent="info"
  />

  <section class="search-panel" aria-label="文章全文搜索">
    <header class="search-guide">
      <span class="guide-icon"><Icon name="lucide:sparkles" class="h-5 w-5" /></span>
      <div>
        <h2>想找什么？</h2>
        <p>搜索会在本地完成，不会上传你的查询内容。</p>
      </div>
      <div class="search-shortcut" aria-hidden="true"><kbd>Ctrl</kbd><span>+</span><kbd>K</kbd></div>
    </header>

    <div id="search-container">
      <div id="pagefind-search" transition:persist></div>
    </div>

    <footer class="search-tips">
      <span><Icon name="lucide:lightbulb" class="h-4 w-4" /> 可以尝试文章标题、分类、标签或正文中的短语</span>
      <a href="/blog/tags">浏览全部标签 <Icon name="lucide:arrow-right" class="h-3.5 w-3.5" /></a>
    </footer>
  </section>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', initSearch)

  function initSearch() {
    const pageFindSearch = document.querySelector('#pagefind-search')
    if (!pageFindSearch || pageFindSearch.querySelector('.pagefind-ui')) return

    const params = new URLSearchParams(window.location.search)
    const onIdle = window.requestIdleCallback || ((cb) => setTimeout(cb, 1))

    onIdle(async () => {
      try {
        // @ts-ignore Pagefind UI does not expose complete client types.
        const { PagefindUI } = await import('@pagefind/default-ui')
        const search = new PagefindUI({
          element: '#pagefind-search',
          showImages: false,
          showSubResults: true,
          translations: {
            placeholder: '搜索文章标题或正文…',
            clear_search: '清除',
            load_more: '加载更多结果',
            search_label: '搜索本站文章',
            filters_label: '筛选',
            zero_results: '没有找到和 “[SEARCH_TERM]” 相关的内容',
            many_results: '找到 [COUNT] 条和 “[SEARCH_TERM]” 相关的结果',
            one_result: '找到 1 条和 “[SEARCH_TERM]” 相关的结果',
            alt_search: '没有找到和 “[SEARCH_TERM]” 相关的内容，显示 “[DIFFERENT_TERM]” 的结果',
            search_suggestion: '没有找到和 “[SEARCH_TERM]” 相关的内容，可以尝试以下搜索：',
            searching: '正在搜索 “[SEARCH_TERM]”…',
          },
          processTerm(term: string) {
            if (term) params.set('q', term)
            else params.delete('q')
            const queryString = params.toString()
            history.replaceState(history.state, '', queryString ? `?${queryString}` : window.location.pathname)
            return term
          },
        })

        const query = params.get('q')
        if (query) search.triggerSearch(query)
      } catch (error) {
        console.error('Error initializing search:', error)
        const searchContainer = document.querySelector('#search-container')
        if (searchContainer) {
          searchContainer.innerHTML = '<div class="search-error">搜索索引暂时无法加载，请稍后重试。</div>'
        }
      }
    })
  }

  document.addEventListener('keydown', (event) => {
    if (!(event.ctrlKey || event.metaKey) || event.key.toLowerCase() !== 'k') return
    const input = document.querySelector('.pagefind-ui__search-input') as HTMLInputElement | null
    if (!input) return
    event.preventDefault()
    input.focus()
  })
</script>

<style>
  .search-panel {
    overflow: hidden;
    border: 1px solid oklch(var(--bc) / 0.09);
    border-radius: 1.65rem;
    background: oklch(var(--b1) / 0.94);
    padding: clamp(1.2rem, 3vw, 2rem);
    box-shadow: 0 20px 60px -48px oklch(var(--bc) / 0.65);
  }

  .search-guide {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.1rem;
  }

  .guide-icon {
    display: flex;
    width: 2.75rem;
    height: 2.75rem;
    align-items: center;
    justify-content: center;
    border-radius: 0.9rem;
    background: oklch(var(--in) / 0.11);
    color: oklch(var(--in));
  }

  .search-guide h2 {
    font-size: 1rem;
    font-weight: 850;
  }

  .search-guide p {
    margin-top: 0.12rem;
    color: oklch(var(--bc) / 0.6);
    font-size: 0.7rem;
  }

  .search-shortcut {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    color: oklch(var(--bc) / 0.45);
    font-size: 0.65rem;
  }

  .search-shortcut kbd {
    min-height: 1.7rem;
    border: 1px solid oklch(var(--bc) / 0.12);
    border-bottom-width: 2px;
    border-radius: 0.45rem;
    background: oklch(var(--b2));
    padding: 0.2rem 0.45rem;
    color: oklch(var(--bc) / 0.7);
    font-family: inherit;
  }

  #search-container {
    min-height: 13rem;
  }

  .search-panel :global(.pagefind-ui__form) {
    position: relative;
  }

  .search-panel :global(.pagefind-ui__search-input) {
    height: 3.7rem;
    border: 1px solid oklch(var(--in) / 0.24) !important;
    border-radius: 1.1rem !important;
    background: oklch(var(--b2) / 0.58) !important;
    padding-right: 5rem !important;
    font-size: 1rem !important;
    box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.14);
    transition: border-color 180ms ease, box-shadow 180ms ease, background 180ms ease;
  }

  .search-panel :global(.pagefind-ui__search-input:focus) {
    border-color: oklch(var(--in) / 0.62) !important;
    background: oklch(var(--b1)) !important;
    box-shadow: 0 0 0 4px oklch(var(--in) / 0.1) !important;
  }

  .search-panel :global(.pagefind-ui__search-clear) {
    display: block !important;
    right: 0.8rem !important;
    border-radius: 0.7rem !important;
    background: oklch(var(--b3) / 0.7) !important;
    padding: 0.4rem 0.65rem !important;
    color: oklch(var(--bc) / 0.65) !important;
    font-size: 0.7rem !important;
  }

  .search-panel :global(.pagefind-ui__drawer) {
    margin-top: 1.25rem;
  }

  .search-panel :global(.pagefind-ui__result) {
    border: 1px solid oklch(var(--bc) / 0.08) !important;
    border-radius: 1rem !important;
    background: oklch(var(--b2) / 0.4);
    padding: 1rem !important;
    transition: transform 180ms ease, border-color 180ms ease;
  }

  .search-panel :global(.pagefind-ui__result:hover) {
    transform: translateY(-2px);
    border-color: oklch(var(--in) / 0.28) !important;
  }

  .search-panel :global(.pagefind-ui__result-link) {
    color: oklch(var(--bc)) !important;
    font-weight: 850 !important;
  }

  .search-panel :global(mark) {
    border-radius: 0.25rem;
    background: oklch(var(--in) / 0.16) !important;
    color: oklch(var(--in)) !important;
    padding: 0 0.16rem;
  }

  .search-panel :global(.search-error) {
    border: 1px dashed oklch(var(--er) / 0.35);
    border-radius: 1rem;
    padding: 2rem;
    color: oklch(var(--er));
    text-align: center;
  }

  .search-tips {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.25rem;
    border-top: 1px solid oklch(var(--bc) / 0.08);
    padding-top: 1rem;
    color: oklch(var(--bc) / 0.58);
    font-size: 0.68rem;
  }

  .search-tips span,
  .search-tips a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .search-tips a {
    color: oklch(var(--in));
    font-weight: 750;
  }

  @media (max-width: 639px) {
    .search-panel {
      border-radius: 1.3rem;
      padding: 1rem;
    }

    .search-shortcut {
      display: none;
    }

    .search-tips {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
